---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GymBase — El sistema que tu gimnasio necesitaba',
  description = 'Gestión de miembros, pagos, rutinas y más. Todo en un solo lugar, desde ₡50,000 al mes.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.gymbase.fit/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- og:image: add a 1200×630 PNG to /public/og-image.png for WhatsApp/social previews -->

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
