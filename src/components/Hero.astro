---
import MockupDashboard from './MockupDashboard.astro';
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background grid lines -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Orange glow top-left -->
  <div class="absolute top-1/3 -left-32 w-96 h-96 bg-[#FF5E14]/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 py-24 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: copy -->
      <div>
        <div class="inline-flex items-center gap-2 bg-[#FF5E14]/10 border border-[#FF5E14]/20 rounded-full px-4 py-1.5 mb-6 animate-fade-up">
          <div class="w-2 h-2 rounded-full bg-[#FF5E14]"></div>
          <span class="text-[#FF5E14] text-xs font-semibold uppercase tracking-wider">Software de gestión para gimnasios</span>
        </div>

        <h1 class="font-heading font-black text-6xl md:text-7xl xl:text-8xl uppercase leading-[0.9] mb-6 animate-fade-up animate-delay-100">
          El sistema<br />
          que tu<br />
          <span class="text-[#FF5E14]">gimnasio</span><br />
          necesitaba.
        </h1>

        <p class="text-[#a0a0a0] text-lg md:text-xl leading-relaxed mb-8 max-w-md animate-fade-up animate-delay-200">
          Gestión de miembros, pagos, rutinas y más. Todo en un solo lugar, desde <strong class="text-white">₡50,000</strong> al mes.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 animate-fade-up animate-delay-300">
          <a
            href="https://youtu.be/r0V__tjlknQ"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#FF5E14] hover:bg-[#e54d0a] text-white font-semibold px-6 py-3.5 rounded transition-colors"
          >
            Ver demo
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/>
            </svg>
          </a>
          <a
            href="#contacto"
            class="inline-flex items-center justify-center border border-[#1f1f1f] hover:border-[#FF5E14]/40 text-white font-semibold px-6 py-3.5 rounded transition-colors"
          >
            Contactar
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex items-center gap-6 mt-10 animate-fade-up animate-delay-400">
          <div class="text-center">
            <p class="font-heading font-black text-2xl text-[#FF5E14]">100%</p>
            <p class="text-[#a0a0a0] text-xs">Web-based</p>
          </div>
          <div class="w-px h-10 bg-[#1f1f1f]"></div>
          <div class="text-center">
            <p class="font-heading font-black text-2xl text-[#FF5E14]">&lt;24h</p>
            <p class="text-[#a0a0a0] text-xs">Configuración</p>
          </div>
          <div class="w-px h-10 bg-[#1f1f1f]"></div>
          <div class="text-center">
            <p class="font-heading font-black text-2xl text-[#FF5E14]">0</p>
            <p class="text-[#a0a0a0] text-xs">Contratos mínimos</p>
          </div>
        </div>
      </div>

      <!-- Right: dashboard mockup -->
      <div id="mockup" class="animate-fade-up animate-delay-400">
        <MockupDashboard />
      </div>
    </div>
  </div>
</section>
