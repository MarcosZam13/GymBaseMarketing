// ── SVG line chart helpers ────────────────────────────────────────────────────
const CW = 280, CH = 65, CPX = 12, CPY = 8;

function svgPts(values: number[]) {
  const n = values.length, min = Math.min(...values), range = Math.max(...values) - min || 1;
  const cW = CW - CPX * 2, cH = CH - CPY * 2;
  return values.map((v, i) => ({
    x: +((CPX + (i / (n - 1)) * cW).toFixed(1)),
    y: +((CPY + cH - ((v - min) / range) * cH).toFixed(1)),
  }));
}

function svgLine(pts: {x:number;y:number}[]) {
  let d = `M${pts[0].x} ${pts[0].y}`;
  for (let i = 1; i < pts.length; i++) {
    const mx = +((pts[i-1].x + pts[i].x) / 2).toFixed(1);
    d += ` C${mx} ${pts[i-1].y},${mx} ${pts[i].y},${pts[i].x} ${pts[i].y}`;
  }
  return d;
}

function svgFill(pts: {x:number;y:number}[]) {
  const last = pts[pts.length - 1];
  return `${svgLine(pts)} L${last.x} ${CH-CPY} L${pts[0].x} ${CH-CPY}Z`;
}

const growthPts = svgPts(growthData.map(d => d.count));
const revPts    = svgPts(revenueData.map(d => d.amount));
const wLostPts  = svgPts(weightLost.map(d => d.lost));
