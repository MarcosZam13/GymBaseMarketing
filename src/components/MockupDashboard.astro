              <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Tienda</h2>
              <p class="text-[#a0a0a0] text-[10px]">6 productos · ₡54,000 vendidos este mes</p>
            </div>
            <button class="bg-[#FF5E14] text-white text-[10px] font-semibold px-3 py-1.5 rounded">+ Producto</button>
          </div>
          <div class="grid grid-cols-2 gap-2">
            {products.map(p => (
              <div class="bg-[#111111] border border-[#1f1f1f] rounded-xl p-3 hover:bg-[#1a1a1a] transition-colors group cursor-pointer">
                <span
                  class="text-[9px] px-1.5 py-0.5 rounded font-medium"
                  style={`background: ${p.color}15; color: ${p.color}`}
                >{p.tag}</span>
                <p class="font-semibold text-[11px] mt-2 mb-1 leading-tight group-hover:text-[#FF5E14] transition-colors">{p.name}</p>
                <div class="flex items-center justify-between mt-2.5">
                  <span class="font-heading font-bold text-sm text-[#FF5E14]">{p.price}</span>
                  <span class="text-[9px] text-[#a0a0a0]">{p.stock} uds.</span>
                </div>
              </div>
            ))}
          </div>
        </div>

      </main>
    </div>
  </div>
</div>

<script>
  // Scope every mockup instance independently to avoid cross-instance interference
  document.querySelectorAll<HTMLElement>('[data-mockup-root]').forEach(root => {
    const tabBtns     = root.querySelectorAll<HTMLButtonElement>('.mockup-tab');
    const sidebarBtns = root.querySelectorAll<HTMLButtonElement>('.sidebar-btn');
    const panels      = root.querySelectorAll<HTMLElement>('.mockup-panel');
    const dayBtns     = root.querySelectorAll<HTMLButtonElement>('.day-btn');
    const dayPanels   = root.querySelectorAll<HTMLElement>('.routine-day-panel');

    function switchTab(index: number) {
      tabBtns.forEach((t, i) => {
        t.classList.toggle('bg-[#FF5E14]/20', i === index);
        t.classList.toggle('text-[#FF5E14]', i === index);
        t.classList.toggle('text-[#a0a0a0]', i !== index);
      });
      sidebarBtns.forEach(btn => {
        const ti = parseInt(btn.dataset.sidebarTab ?? '-1');
        btn.classList.toggle('bg-[#FF5E14]/15', ti === index);
        btn.classList.toggle('text-[#FF5E14]', ti === index);
        btn.classList.toggle('text-[#a0a0a0]', ti !== index);
      });
      panels.forEach((p, i) => p.classList.toggle('hidden', i !== index));
    }

    function switchDay(index: number) {
      dayBtns.forEach((b, i) => {
        b.classList.toggle('bg-[#FF5E14]/10', i === index);
        b.classList.toggle('border-[#FF5E14]', i === index);
        b.classList.toggle('text-[#FF5E14]', i === index);
        b.classList.toggle('bg-[#111111]', i !== index);
        b.classList.toggle('border-[#1f1f1f]', i !== index);
        b.classList.toggle('text-[#a0a0a0]', i !== index);
      });
      dayPanels.forEach((p, i) => p.classList.toggle('hidden', i !== index));
    }

    tabBtns.forEach(btn => btn.addEventListener('click', () => switchTab(parseInt(btn.dataset.tab!))));
    sidebarBtns.forEach(btn => btn.addEventListener('click', () => {
      const ti = parseInt(btn.dataset.sidebarTab ?? '-1');
      if (ti >= 0) switchTab(ti);
    }));
    dayBtns.forEach(btn => btn.addEventListener('click', () => switchDay(parseInt(btn.dataset.dayBtn!))));
  });
</script>
