---
const tabs = ['Dashboard', 'Miembros', 'Pagos', 'Rutinas', 'Check-in', 'Reportes'];

const sidebar = [
  { icon: '⊞', label: 'Dashboard', tab: 0 },
  { icon: '👥', label: 'Miembros', tab: 1 },
  { icon: '💳', label: 'Pagos', tab: 2 },
  { icon: '🏋️', label: 'Rutinas', tab: 3 },
  { icon: '✅', label: 'Check-in', tab: 4 },
  { icon: '📊', label: 'Reportes', tab: 5 },
];

const members = [
  { name: 'Carlos Vega',    plan: 'Mensual',    status: 'Al día',  checkin: 'Hoy 7:14am',  vence: '15 jun',     amount: '₡25,000',  date: '1 may',  ok: true  },
  { name: 'María Solís',    plan: 'Trimestral', status: 'Al día',  checkin: 'Hoy 6:52am',  vence: '1 ago',      amount: '₡65,000',  date: '1 may',  ok: true  },
  { name: 'Andrés Mora',    plan: 'Mensual',    status: 'Vencido', checkin: 'Hace 4 días', vence: '18 may',     amount: '₡25,000',  date: '—',      ok: false },
  { name: 'Sofía Castro',   plan: 'Mensual',    status: 'Al día',  checkin: 'Hoy 8:01am',  vence: '22 jun',     amount: '₡25,000',  date: '2 may',  ok: true  },
  { name: 'Diego Araya',    plan: 'Anual',      status: 'Al día',  checkin: 'Ayer 5:45pm', vence: '1 ene 2027', amount: '₡240,000', date: '1 ene',  ok: true  },
  { name: 'Laura Jiménez',  plan: 'Mensual',    status: 'Al día',  checkin: 'Hoy 9:20am',  vence: '30 jun',     amount: '₡25,000',  date: '3 may',  ok: true  },
  { name: 'Felipe Rojas',   plan: 'Mensual',    status: 'Vencido', checkin: 'Hace 8 días', vence: '10 may',     amount: '₡25,000',  date: '—',      ok: false },
];

const days = [
  {
    label: 'Día 1 · Pecho',
    exercises: [
      { name: 'Press de banca', sets: 4, reps: '8',  rest: '90s', muscle: 'Pecho'    },
      { name: 'Aperturas',      sets: 3, reps: '12', rest: '60s', muscle: 'Pecho'    },
      { name: 'Press inclinado',sets: 3, reps: '10', rest: '75s', muscle: 'Pecho'    },
      { name: 'Fondos',         sets: 3, reps: '10', rest: '60s', muscle: 'Tríceps'  },
      { name: 'Press militar',  sets: 3, reps: '10', rest: '60s', muscle: 'Hombros'  },
    ],
  },
  {
    label: 'Día 2 · Espalda',
    exercises: [
      { name: 'Peso muerto',     sets: 4, reps: '6',  rest: '120s', muscle: 'Espalda' },
      { name: 'Jalones al pecho',sets: 3, reps: '10', rest: '75s',  muscle: 'Espalda' },
      { name: 'Remo con barra',  sets: 3, reps: '10', rest: '75s',  muscle: 'Espalda' },
      { name: 'Curl de bíceps',  sets: 3, reps: '12', rest: '60s',  muscle: 'Bíceps'  },
      { name: 'Curl martillo',   sets: 3, reps: '12', rest: '60s',  muscle: 'Bíceps'  },
    ],
  },
  {
    label: 'Día 3 · Piernas',
    exercises: [
      { name: 'Sentadilla',      sets: 4, reps: '10', rest: '90s', muscle: 'Piernas'  },
      { name: 'Prensa',          sets: 3, reps: '12', rest: '75s', muscle: 'Piernas'  },
      { name: 'Extensiones',     sets: 3, reps: '15', rest: '60s', muscle: 'Piernas'  },
      { name: 'Curl femoral',    sets: 3, reps: '12', rest: '60s', muscle: 'Piernas'  },
      { name: 'Plancha',         sets: 3, reps: '30s', rest: '45s', muscle: 'Core'    },
    ],
  },
];

const muscleColors: Record<string, string> = {
  Pecho: '#FF5E14', Espalda: '#38BDF8', Hombros: '#A855F7',
  Bíceps: '#FACC15', Tríceps: '#FACC15', Piernas: '#EF4444',
  Core: '#22C55E', Cardio: '#38BDF8',
};

const checkins = [
  { name: 'Laura Jiménez', time: '09:20am', plan: 'Mensual',    ok: true  },
  { name: 'Sofía Castro',  time: '08:01am', plan: 'Mensual',    ok: true  },
  { name: 'Carlos Vega',   time: '07:14am', plan: 'Mensual',    ok: true  },
  { name: 'María Solís',   time: '06:52am', plan: 'Trimestral', ok: true  },
  { name: 'Diego Araya',   time: '06:31am', plan: 'Anual',      ok: true  },
  { name: 'Andrés Mora',   time: '06:15am', plan: 'Mensual',    ok: false },
  { name: 'Karla Núñez',   time: '06:02am', plan: 'Mensual',    ok: true  },
];

// Bar chart data: last 6 months member count
const growthData = [
  { month: 'Dic', count: 104 },
  { month: 'Ene', count: 115 },
  { month: 'Feb', count: 122 },
  { month: 'Mar', count: 129 },
  { month: 'Abr', count: 138 },
  { month: 'May', count: 147 },
];
const maxCount = Math.max(...growthData.map(d => d.count));

const revenueData = [
  { month: 'Dic', amount: 1840000 },
  { month: 'Ene', amount: 2050000 },
  { month: 'Feb', amount: 2120000 },
  { month: 'Mar', amount: 2250000 },
  { month: 'Abr', amount: 2300000 },
  { month: 'May', amount: 2350000 },
];
const maxRevenue = Math.max(...revenueData.map(d => d.amount));

function fmtColones(n: number) {
  if (n >= 1000000) return `₡${(n / 1000000).toFixed(1)}M`;
  return `₡${(n / 1000).toFixed(0)}K`;
}
---

<div class="relative w-full max-w-2xl mx-auto lg:mx-0">
  <div class="absolute -inset-4 bg-[#FF5E14]/10 rounded-2xl blur-3xl pointer-events-none"></div>

  <div class="relative rounded-xl border border-[#1f1f1f] bg-[#0d0d0d] overflow-hidden shadow-2xl">

    <!-- Title bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-[#1f1f1f] bg-[#111111]">
      <div class="w-3 h-3 rounded-full bg-[#EF4444]"></div>
      <div class="w-3 h-3 rounded-full bg-[#FACC15]"></div>
      <div class="w-3 h-3 rounded-full bg-[#22C55E]"></div>
      <span class="ml-2 text-[10px] text-[#a0a0a0] font-mono hidden sm:block">gymbase.app</span>
      <div class="ml-auto flex items-center gap-0.5">
        {tabs.map((tab, i) => (
          <button
            data-tab={i}
            class={`mockup-tab text-[10px] px-2 py-1 rounded transition-colors whitespace-nowrap ${i === 0 ? 'bg-[#FF5E14]/20 text-[#FF5E14]' : 'text-[#a0a0a0] hover:text-white'}`}
          >{tab}</button>
        ))}
      </div>
    </div>

    <div class="flex" style="min-height: 480px;">

      <!-- Sidebar -->
      <aside class="w-12 md:w-44 border-r border-[#1f1f1f] bg-[#0a0a0a] py-4 flex-shrink-0">
        <div class="hidden md:flex items-center gap-2 px-4 mb-6">
          <div class="w-6 h-6 bg-[#FF5E14] rounded flex items-center justify-center text-white text-[10px] font-black">G</div>
          <span class="font-heading font-black text-sm uppercase tracking-wide">GymBase</span>
        </div>
        <nav class="flex flex-col gap-1 px-2">
          {sidebar.map(item => (
            <button
              data-sidebar-tab={item.tab}
              class={`sidebar-btn w-full flex items-center gap-3 px-2 py-2 rounded text-sm transition-colors ${
                item.tab === 0 ? 'bg-[#FF5E14]/15 text-[#FF5E14]' : 'text-[#a0a0a0] hover:text-white hover:bg-[#1f1f1f]'
              }`}
            >
              <span class="text-sm flex-shrink-0">{item.icon}</span>
              <span class="hidden md:block text-xs font-medium">{item.label}</span>
            </button>
          ))}
        </nav>
      </aside>

      <!-- Main -->
      <main class="flex-1 overflow-hidden">

        <!-- 0: Dashboard -->
        <div data-panel="0" class="mockup-panel p-4">
          <div class="mb-4">
            <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Panel de Control</h2>
            <p class="text-[#a0a0a0] text-[10px]">Viernes, 22 de mayo 2026</p>
          </div>
          <div class="grid grid-cols-3 gap-2 mb-3">
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-3">
              <p class="text-[#a0a0a0] text-[9px] uppercase tracking-wider mb-1">Miembros activos</p>
              <p class="font-heading font-bold text-xl text-[#FF5E14]">147</p>
              <p class="text-[#22C55E] text-[9px] mt-1">+8 este mes</p>
            </div>
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-3">
              <p class="text-[#a0a0a0] text-[9px] uppercase tracking-wider mb-1">Pagos mayo</p>
              <p class="font-heading font-bold text-base leading-tight">₡2.35M</p>
              <p class="text-[#22C55E] text-[9px] mt-1">94% cobrado</p>
            </div>
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-3">
              <p class="text-[#a0a0a0] text-[9px] uppercase tracking-wider mb-1">Check-ins hoy</p>
              <p class="font-heading font-bold text-xl">34</p>
              <p class="text-[#a0a0a0] text-[9px] mt-1">Pico: 6–8am</p>
            </div>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg overflow-hidden">
            <div class="px-3 py-2 border-b border-[#1f1f1f] flex items-center justify-between">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[#a0a0a0]">Miembros recientes</span>
              <span class="text-[10px] text-[#FF5E14]">Ver todos →</span>
            </div>
            <table class="w-full">
              <thead><tr class="border-b border-[#1f1f1f]">
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px]">Nombre</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px] hidden md:table-cell">Plan</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px]">Estado</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px] hidden lg:table-cell">Último check-in</th>
              </tr></thead>
              <tbody>
                {members.slice(0, 5).map(m => (
                  <tr class="border-b border-[#1f1f1f]/50">
                    <td class="px-3 py-1.5 font-medium text-xs">{m.name}</td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden md:table-cell">{m.plan}</td>
                    <td class="px-3 py-1.5"><span class={`px-1.5 py-0.5 rounded text-[9px] font-semibold ${m.ok ? 'bg-[#22C55E]/15 text-[#22C55E]' : 'bg-[#EF4444]/15 text-[#EF4444]'}`}>{m.status}</span></td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden lg:table-cell">{m.checkin}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- 1: Miembros -->
        <div data-panel="1" class="mockup-panel hidden p-4">
          <div class="mb-3 flex items-center justify-between">
            <div>
              <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Miembros</h2>
              <p class="text-[#a0a0a0] text-[10px]">147 registrados · 138 activos</p>
            </div>
            <button class="bg-[#FF5E14] text-white text-[10px] font-semibold px-3 py-1.5 rounded">+ Agregar</button>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded px-3 py-2 mb-3 flex items-center gap-2">
            <svg class="w-3 h-3 text-[#a0a0a0] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span class="text-[#404040] text-xs">Buscar por nombre, email o teléfono...</span>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg overflow-hidden">
            <table class="w-full">
              <thead><tr class="border-b border-[#1f1f1f]">
                <th class="text-left px-3 py-2 text-[#a0a0a0] font-medium text-[10px]">Nombre</th>
                <th class="text-left px-3 py-2 text-[#a0a0a0] font-medium text-[10px] hidden md:table-cell">Plan</th>
                <th class="text-left px-3 py-2 text-[#a0a0a0] font-medium text-[10px]">Estado</th>
                <th class="text-left px-3 py-2 text-[#a0a0a0] font-medium text-[10px] hidden lg:table-cell">Vence</th>
              </tr></thead>
              <tbody>
                {members.map(m => (
                  <tr class="border-b border-[#1f1f1f]/50 hover:bg-[#1a1a1a] cursor-pointer">
                    <td class="px-3 py-1.5 font-medium text-xs">{m.name}</td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden md:table-cell">{m.plan}</td>
                    <td class="px-3 py-1.5"><span class={`px-1.5 py-0.5 rounded text-[9px] font-semibold ${m.ok ? 'bg-[#22C55E]/15 text-[#22C55E]' : 'bg-[#EF4444]/15 text-[#EF4444]'}`}>{m.status}</span></td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden lg:table-cell">{m.vence}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- 2: Pagos -->
        <div data-panel="2" class="mockup-panel hidden p-4">
          <div class="mb-3">
            <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Pagos — Mayo 2026</h2>
            <p class="text-[#a0a0a0] text-[10px]">₡2,350,000 cobrados de ₡2,500,000</p>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-3 mb-3">
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-[10px] text-[#a0a0a0]">Cobrado este mes</span>
              <span class="text-[10px] font-semibold text-[#22C55E]">94%</span>
            </div>
            <div class="h-1.5 bg-[#1f1f1f] rounded-full overflow-hidden">
              <div class="h-full bg-[#22C55E] rounded-full" style="width: 94%"></div>
            </div>
            <div class="flex justify-between mt-1.5">
              <span class="text-[9px] text-[#22C55E]">₡2,350,000 cobrados</span>
              <span class="text-[9px] text-[#EF4444]">₡150,000 pendientes</span>
            </div>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg overflow-hidden">
            <div class="px-3 py-2 border-b border-[#1f1f1f] flex items-center justify-between">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[#a0a0a0]">Historial</span>
              <div class="flex gap-1">
                <span class="bg-[#22C55E]/15 text-[#22C55E] text-[9px] px-1.5 py-0.5 rounded">Cobrado</span>
                <span class="bg-[#EF4444]/15 text-[#EF4444] text-[9px] px-1.5 py-0.5 rounded">Pendiente</span>
              </div>
            </div>
            <table class="w-full">
              <thead><tr class="border-b border-[#1f1f1f]">
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px]">Miembro</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px] hidden md:table-cell">Monto</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px]">Estado</th>
                <th class="text-left px-3 py-1.5 text-[#a0a0a0] font-medium text-[10px] hidden lg:table-cell">Fecha</th>
              </tr></thead>
              <tbody>
                {members.map(m => (
                  <tr class="border-b border-[#1f1f1f]/50">
                    <td class="px-3 py-1.5 font-medium text-xs">{m.name}</td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden md:table-cell">{m.amount}</td>
                    <td class="px-3 py-1.5"><span class={`px-1.5 py-0.5 rounded text-[9px] font-semibold ${m.ok ? 'bg-[#22C55E]/15 text-[#22C55E]' : 'bg-[#EF4444]/15 text-[#EF4444]'}`}>{m.ok ? 'Cobrado' : 'Pendiente'}</span></td>
                    <td class="px-3 py-1.5 text-[#a0a0a0] text-xs hidden lg:table-cell">{m.date}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- 3: Rutinas — estilo MyRoutineView -->
        <div data-panel="3" class="mockup-panel hidden p-4">
          <!-- Header card: igual a MyRoutineView -->
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-xl p-4 mb-3">
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-start gap-3">
                <!-- Dumbbell icon -->
                <div class="w-9 h-9 rounded-xl bg-[#FF5E14]/10 border border-[#FF5E14]/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-[#FF5E14]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h2m14 0h2M7 12V9a1 1 0 011-1h1M7 12v3a1 1 0 001 1h1m4-4V9a1 1 0 011-1h1m-2 4v3a1 1 0 001 1h1"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-sm leading-tight">Fuerza General</p>
                  <p class="text-[#a0a0a0] text-[10px] mt-0.5">Objetivo: Ganar masa muscular</p>
                  <div class="flex flex-wrap gap-3 mt-1.5">
                    <span class="text-[#a0a0a0] text-[10px] flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/><path d="M16 2v4M8 2v4M3 10h18" stroke-width="2" stroke-linecap="round"/></svg>
                      3 días/semana
                    </span>
                    <span class="text-[#a0a0a0] text-[10px] flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="2"/><path d="M12 7v5l3 3" stroke-width="2" stroke-linecap="round"/></svg>
                      8 semanas
                    </span>
                    <span class="text-[#a0a0a0] text-[10px] flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12h2m14 0h2M7 12V9a1 1 0 011-1h1M7 12v3a1 1 0 001 1h1m4-4V9a1 1 0 011-1h1m-2 4v3a1 1 0 001 1h1" stroke-width="2" stroke-linecap="round"/></svg>
                      15 ejercicios
                    </span>
                  </div>
                </div>
              </div>
              <span class="px-2 py-0.5 rounded-full bg-[#22C55E]/10 border border-[#22C55E]/25 text-[9px] text-[#22C55E] font-semibold flex-shrink-0">Activa</span>
            </div>
            <!-- Progress dots (days/week) — exactly like MyRoutineView -->
            <div class="mt-3 flex gap-1.5">
              {[0,1,2].map(i => (
                <div class={`flex-1 h-1.5 rounded-full ${i === 0 ? 'bg-[#FF5E14]' : 'bg-[#1f1f1f]'}`}></div>
              ))}
            </div>
          </div>

          <!-- Day selector pills — horizontal, like MyRoutineView -->
          <div class="flex gap-1.5 mb-3 overflow-x-auto pb-1">
            {days.map((day, i) => (
              <button
                data-day-btn={i}
                class={`day-btn flex-shrink-0 px-3 py-1.5 rounded-full text-[10px] font-medium border transition-all ${
                  i === 0
                    ? 'bg-[#FF5E14]/10 border-[#FF5E14] text-[#FF5E14]'
                    : 'bg-[#111111] border-[#1f1f1f] text-[#a0a0a0] hover:border-[#FF5E14]/40 hover:text-white'
                }`}
              >{day.label}</button>
            ))}
          </div>

          <!-- Exercise list — divided rows, like MyRoutineView -->
          {days.map((day, di) => (
            <div
              data-day-panel={di}
              class={`routine-day-panel bg-[#111111] border border-[#1f1f1f] rounded-xl overflow-hidden ${di !== 0 ? 'hidden' : ''}`}
            >
              <div class="px-4 py-2.5 border-b border-[#1f1f1f] flex items-center justify-between">
                <p class="font-semibold text-xs">{day.label.split(' · ')[0]}</p>
                <p class="text-[#a0a0a0] text-[10px]">{day.exercises.length} ejercicios</p>
              </div>
              <div class="divide-y divide-[#1f1f1f]">
                {day.exercises.map((ex, i) => {
                  const color = muscleColors[ex.muscle] ?? '#a0a0a0';
                  return (
                    <div class="flex items-center gap-3 px-4 py-3 hover:bg-[#1a1a1a] transition-colors">
                      <!-- Number badge -->
                      <div class="w-7 h-7 rounded-lg bg-[#1f1f1f] flex items-center justify-center text-[10px] font-bold text-[#a0a0a0] flex-shrink-0">{i + 1}</div>
                      <!-- Info -->
                      <div class="flex-1 min-w-0">
                        <p class="font-medium text-xs text-white">{ex.name}</p>
                        <div class="flex items-center gap-3 mt-0.5">
                          <span class="text-[9px] text-[#a0a0a0] flex items-center gap-1">
                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h5M20 20v-5h-5M5 19A9 9 0 1 0 5 5"/></svg>
                            {ex.sets} × {ex.reps} reps
                          </span>
                          <span class="text-[9px] text-[#38BDF8] flex items-center gap-1">
                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="2"/><path d="M12 7v5l3 3" stroke-width="2" stroke-linecap="round"/></svg>
                            {ex.rest}
                          </span>
                        </div>
                      </div>
                      <!-- Muscle badge -->
                      <span
                        class="px-2 py-0.5 rounded-full text-[9px] font-medium flex-shrink-0"
                        style={`background: ${color}18; color: ${color}; border: 0.5px solid ${color}40`}
                      >{ex.muscle}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        <!-- 4: Check-in -->
        <div data-panel="4" class="mockup-panel hidden p-4">
          <div class="mb-3 flex items-center justify-between">
            <div>
              <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Check-in</h2>
              <p class="text-[#a0a0a0] text-[10px]">Hoy, 22 de mayo — 34 entradas</p>
            </div>
            <button class="bg-[#FF5E14] text-white text-[10px] font-semibold px-3 py-1.5 rounded flex items-center gap-1.5">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.24M16.24 12l1.76-1.76M15 9l-2-2m-1 1l-.12-.12M3 3l18 18"/></svg>
              Escanear QR
            </button>
          </div>
          <div class="grid grid-cols-3 gap-2 mb-3">
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-2.5 text-center">
              <p class="font-heading font-bold text-lg text-[#FF5E14]">34</p>
              <p class="text-[#a0a0a0] text-[9px]">entradas hoy</p>
            </div>
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-2.5 text-center">
              <p class="font-heading font-bold text-lg">6–8am</p>
              <p class="text-[#a0a0a0] text-[9px]">hora pico</p>
            </div>
            <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-2.5 text-center">
              <p class="font-heading font-bold text-lg text-[#22C55E]">97%</p>
              <p class="text-[#a0a0a0] text-[9px]">con membresía</p>
            </div>
          </div>
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg overflow-hidden">
            <div class="px-3 py-2 border-b border-[#1f1f1f]">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[#a0a0a0]">Registro del día</span>
            </div>
            <div class="divide-y divide-[#1f1f1f]/60">
              {checkins.map(c => (
                <div class="flex items-center gap-3 px-3 py-2">
                  <div class="w-7 h-7 rounded-full bg-[#1f1f1f] flex items-center justify-center flex-shrink-0">
                    <span class="text-[10px] font-bold text-[#a0a0a0]">{c.name.split(' ').map((n: string) => n[0]).join('')}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-medium leading-none mb-0.5">{c.name}</p>
                    <p class="text-[9px] text-[#a0a0a0]">{c.plan}</p>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <span class="text-[10px] text-[#a0a0a0]">{c.time}</span>
                    <span class={`w-2 h-2 rounded-full flex-shrink-0 ${c.ok ? 'bg-[#22C55E]' : 'bg-[#EF4444]'}`}></span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 5: Reportes -->
        <div data-panel="5" class="mockup-panel hidden p-4">
          <div class="mb-3 flex items-center justify-between">
            <div>
              <h2 class="font-heading font-bold text-sm uppercase tracking-wide">Reportes</h2>
              <p class="text-[#a0a0a0] text-[10px]">Últimos 6 meses</p>
            </div>
            <div class="flex items-center gap-1.5 bg-[#111111] border border-[#1f1f1f] rounded px-2 py-1">
              <span class="text-[10px] text-[#a0a0a0]">Dic 2025 – May 2026</span>
            </div>
          </div>

          <!-- Top stats -->
          <div class="grid grid-cols-4 gap-2 mb-3">
            {[
              { label: 'Miembros', value: '147', delta: '+43', up: true },
              { label: 'Ingresos', value: '₡2.35M', delta: '+27%', up: true },
              { label: 'Check-ins', value: '856', delta: '+18%', up: true },
              { label: 'Bajas', value: '12', delta: '-3', up: false },
            ].map(s => (
              <div class="bg-[#111111] border border-[#1f1f1f] rounded-lg p-2.5">
                <p class="text-[#a0a0a0] text-[9px] uppercase tracking-wider mb-1">{s.label}</p>
                <p class="font-heading font-bold text-sm leading-tight">{s.value}</p>
                <p class={`text-[9px] mt-0.5 ${s.up ? 'text-[#22C55E]' : 'text-[#EF4444]'}`}>{s.delta}</p>
              </div>
            ))}
          </div>

          <!-- Member growth chart -->
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-xl p-3 mb-3">
            <div class="flex items-center justify-between mb-3">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-[#a0a0a0]">Crecimiento de miembros</p>
              <span class="text-[9px] text-[#22C55E] font-semibold">+41% en 6 meses</span>
            </div>
            <div class="flex items-end gap-1.5 h-20">
              {growthData.map((d, i) => {
                const pct = Math.round((d.count / maxCount) * 100);
                const isLast = i === growthData.length - 1;
                return (
                  <div class="flex-1 flex flex-col items-center gap-1">
                    <span class="text-[8px] text-[#a0a0a0]">{d.count}</span>
                    <div
                      class={`w-full rounded-t transition-all ${isLast ? 'bg-[#FF5E14]' : 'bg-[#FF5E14]/30'}`}
                      style={`height: ${pct}%`}
                    ></div>
                    <span class="text-[8px] text-[#a0a0a0]">{d.month}</span>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Revenue chart -->
          <div class="bg-[#111111] border border-[#1f1f1f] rounded-xl p-3">
            <div class="flex items-center justify-between mb-3">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-[#a0a0a0]">Ingresos mensuales</p>
              <span class="text-[9px] text-[#22C55E] font-semibold">+27% vs. hace 6 meses</span>
            </div>
            <div class="flex items-end gap-1.5 h-16">
              {revenueData.map((d, i) => {
                const pct = Math.round((d.amount / maxRevenue) * 100);
                const isLast = i === revenueData.length - 1;
                return (
                  <div class="flex-1 flex flex-col items-center gap-1">
                    <span class="text-[8px] text-[#a0a0a0]">{fmtColones(d.amount)}</span>
                    <div
                      class={`w-full rounded-t ${isLast ? 'bg-[#22C55E]' : 'bg-[#22C55E]/30'}`}
                      style={`height: ${pct}%`}
                    ></div>
                    <span class="text-[8px] text-[#a0a0a0]">{d.month}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</div>

<script>
  const tabBtns      = document.querySelectorAll<HTMLButtonElement>('.mockup-tab');
  const sidebarBtns  = document.querySelectorAll<HTMLButtonElement>('.sidebar-btn');
  const panels       = document.querySelectorAll<HTMLElement>('.mockup-panel');
  const dayBtns      = document.querySelectorAll<HTMLButtonElement>('.day-btn');
  const dayPanels    = document.querySelectorAll<HTMLElement>('.routine-day-panel');

  function switchTab(index: number) {
    tabBtns.forEach((t, i) => {
      t.classList.toggle('bg-[#FF5E14]/20', i === index);
      t.classList.toggle('text-[#FF5E14]', i === index);
      t.classList.toggle('text-[#a0a0a0]', i !== index);
    });
    sidebarBtns.forEach(btn => {
      const ti = parseInt(btn.dataset.sidebarTab ?? '-1');
      btn.classList.toggle('bg-[#FF5E14]/15', ti === index);
      btn.classList.toggle('text-[#FF5E14]', ti === index);
      btn.classList.toggle('text-[#a0a0a0]', ti !== index);
    });
    panels.forEach((p, i) => p.classList.toggle('hidden', i !== index));
  }

  function switchDay(index: number) {
    dayBtns.forEach((b, i) => {
      b.classList.toggle('bg-[#FF5E14]/10', i === index);
      b.classList.toggle('border-[#FF5E14]', i === index);
      b.classList.toggle('text-[#FF5E14]', i === index);
      b.classList.toggle('bg-[#111111]', i !== index);
      b.classList.toggle('border-[#1f1f1f]', i !== index);
      b.classList.toggle('text-[#a0a0a0]', i !== index);
    });
    dayPanels.forEach((p, i) => p.classList.toggle('hidden', i !== index));
  }

  tabBtns.forEach(btn => btn.addEventListener('click', () => switchTab(parseInt(btn.dataset.tab!))));
  sidebarBtns.forEach(btn => btn.addEventListener('click', () => {
    const ti = parseInt(btn.dataset.sidebarTab ?? '-1');
    if (ti >= 0) switchTab(ti);
  }));
  dayBtns.forEach(btn => btn.addEventListener('click', () => switchDay(parseInt(btn.dataset.dayBtn!))));
</script>
