---
const features = [
  {
    color: '#A855F7',
    title: 'Clases y horarios',
    desc: 'Publicá tu horario de clases, controlá los cupos y dejá que tus miembros se inscriban desde el celular.',
    highlights: ['Inscripción en línea', 'Control de cupos por clase', 'Recordatorios automáticos'],
    iconSvg: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z"/></svg>`,
  },
  {
    color: '#FACC15',
    title: 'Retos de comunidad',
    desc: 'Creá retos colectivos — de consistencia, pérdida de peso o fuerza — y mantené la motivación del grupo alta.',
    highlights: ['Retos por período', 'Rankings en tiempo real', 'Metas individuales y grupales'],
    iconSvg: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/></svg>`,
  },
  {
    color: '#38BDF8',
    title: 'Seguimiento de progreso',
    desc: 'Cada miembro puede registrar medidas, peso y fotos. Ver su evolución es lo que los hace volver.',
    highlights: ['Registro de medidas y peso', 'Gráficas de evolución', 'Historial fotográfico'],
    iconSvg: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>`,
  },
  {
    color: '#22C55E',
    title: 'Tienda del gimnasio',
    desc: 'Vendé suplementos, ropa y accesorios directamente desde la plataforma. Sin intermediarios, sin complicaciones.',
    highlights: ['Catálogo de productos', 'Historial de compras por miembro', 'Ingresos adicionales sin esfuerzo'],
    iconSvg: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z"/></svg>`,
  },
];
---

<section id="engagement" class="py-24 border-t border-[#1f1f1f]">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-16 max-w-2xl">
      <p class="text-[#FF5E14] text-sm font-semibold uppercase tracking-widest mb-3">Engagement</p>
      <h2 class="font-heading font-black text-5xl md:text-6xl uppercase leading-tight mb-6">
        Una app que tus miembros van a querer usar
      </h2>
      <p class="text-[#a0a0a0] leading-relaxed">
        Más allá de la gestión — herramientas que generan hábito, comunidad y lealtad en cada persona de tu gimnasio.
      </p>
    </div>

    <!-- 2x2 Grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {features.map(f => (
        <div class="relative overflow-hidden rounded-2xl border border-[#1f1f1f] bg-[#111111] p-8 group transition-all duration-300">

          <!-- Top accent bar -->
          <div class="absolute inset-x-0 top-0 h-0.5" style={`background: ${f.color}`}></div>

          <!-- Large faded background icon -->
          <div class="absolute -right-4 -top-4 w-36 h-36 opacity-[0.045] pointer-events-none" style={`color: ${f.color}`}>
            <Fragment set:html={f.iconSvg} />
          </div>

          <!-- Hover glow -->
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl pointer-events-none"
            style={`background: radial-gradient(ellipse at 0% 0%, ${f.color}10 0%, transparent 65%)`}
          ></div>

          <!-- Icon badge -->
          <div
            class="relative z-10 w-12 h-12 rounded-xl flex items-center justify-center mb-6"
            style={`background: ${f.color}18; border: 1px solid ${f.color}35`}
          >
            <div class="w-6 h-6" style={`color: ${f.color}`}>
              <Fragment set:html={f.iconSvg} />
            </div>
          </div>

          <!-- Title -->
          <h3 class="relative z-10 font-heading font-bold text-2xl md:text-3xl uppercase mb-3">{f.title}</h3>

          <!-- Desc -->
          <p class="relative z-10 text-[#a0a0a0] text-sm leading-relaxed mb-6">{f.desc}</p>

          <!-- Highlights -->
          <ul class="relative z-10 space-y-2.5">
            {f.highlights.map(h => (
              <li class="flex items-center gap-3 text-sm">
                <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${f.color}`}></div>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
