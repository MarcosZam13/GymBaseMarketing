---
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-heading font-black text-2xl tracking-tight uppercase">
      GYM<span class="text-[#FF5E14]">BASE</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/#caracteristicas" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Características</a>
      <a href="/#como-funciona" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Cómo funciona</a>
      <a href="/#precios" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Precios</a>
      <a href="/#faq" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">FAQ</a>
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a
        href="/#contacto"
        class="hidden md:inline-flex bg-[#FF5E14] hover:bg-[#e54d0a] text-white font-semibold text-sm px-5 py-2.5 rounded transition-colors"
      >
        Comenzar ahora
      </a>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-[#a0a0a0] hover:text-white"
        aria-label="Menú"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#1f1f1f] bg-[#080808]">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-4">
      <a href="/#caracteristicas" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Características</a>
      <a href="/#como-funciona" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Cómo funciona</a>
      <a href="/#precios" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">Precios</a>
      <a href="/#faq" class="text-sm text-[#a0a0a0] hover:text-white transition-colors">FAQ</a>
      <a
        href="/#contacto"
        class="inline-flex justify-center bg-[#FF5E14] hover:bg-[#e54d0a] text-white font-semibold text-sm px-5 py-2.5 rounded transition-colors"
      >
        Comenzar ahora
      </a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll opacity — don't change bg while mobile menu is open
  window.addEventListener('scroll', () => {
    if (!mobileMenu.classList.contains('hidden')) return;
    if (window.scrollY > 20) {
      navbar.style.backgroundColor = 'rgba(8,8,8,0.95)';
      navbar.style.backdropFilter = 'blur(12px)';
      navbar.style.borderBottom = '1px solid #1f1f1f';
    } else {
      navbar.style.backgroundColor = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  });

  // Mobile menu toggle
  mobileMenuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);

    if (!isOpen) {
      // Menu opening — force solid background regardless of scroll position
      navbar.style.backgroundColor = 'rgba(8,8,8,0.98)';
      navbar.style.backdropFilter = 'blur(12px)';
      navbar.style.borderBottom = '1px solid #1f1f1f';
    } else if (window.scrollY <= 20) {
      // Menu closing and still at top — restore transparent
      navbar.style.backgroundColor = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
